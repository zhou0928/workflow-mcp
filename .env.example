# Workflow MCP Server Configuration
# Copy to .env and fill in your values

# Git
GIT_DEFAULT_BRANCH=main
GIT_REMOTE_NAME=origin

# Deployment
DEPLOY_SCRIPT=./deploy.sh
DEPLOY_WORK_DIR=./dist

# File Processing
FILE_MAX_SIZE_MB=100

# Notification Channels
# Slack
NOTIFY_SLACK_WEBHOOK=
# WeChat Work (企业微信)
NOTIFY_WECOM_KEY=
# SMTP Email
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_EMAIL_FROM=workflow-mcp@localhost
NOTIFY_EMAIL_TO=

# AI Code Review
AI_REVIEW_API_KEY=
AI_REVIEW_API_URL=https://api.openai.com/v1
AI_REVIEW_MODEL=gpt-4o-mini

# Logging
LOG_LEVEL=info
